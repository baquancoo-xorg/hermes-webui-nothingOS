# Hermes WebUI All-in-One — config mẫu. Copy thành .env rồi điền.
# Mật khẩu đăng nhập (bỏ trống = tắt auth, ai vào cũng được — KHÔNG khuyến nghị khi mở mạng)
HERMES_WEBUI_PASSWORD=

# Cổng web (mặc định 8787). Người dùng vào http://127.0.0.1:8787
HERMES_WEBUI_PORT=8787

# Thư mục lưu state (session, settings). Mặc định ~/.hermes/webui
# HERMES_WEBUI_STATE_DIR=

# (Tùy chọn) Vị trí engine hermes-agent nếu không ở ~/.hermes/hermes-agent
# HERMES_HOME=
